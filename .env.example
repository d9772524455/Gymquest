# Gym Quest — docker-compose environment.
# Copy to .env and fill in values. Never commit .env.
# Server-level env vars live in server/.env.example (used when running without docker).

POSTGRES_DB=gymquest
POSTGRES_USER=gymquest
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# 64 random hex chars — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_HEX

NODE_ENV=production

# Optional SMTP (see server/.env.example for details)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
