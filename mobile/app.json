{
  "expo": {
    "name": "Gym Quest",
    "slug": "gymquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0e14"
    },
    "ios": {
      "bundleIdentifier": "fit.gymquest.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Для синхронизации данных о тренировках",
        "NSHealthUpdateUsageDescription": "Для записи данных о тренировках",
        "NSCameraUsageDescription": "Для сканирования QR-кода чекина"
      }
    },
    "android": {
      "package": "fit.gymquest.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c0e14"
      },
      "permissions": [
        "CAMERA",
        "ACTIVITY_RECOGNITION"
      ]
    },
    "plugins": [
      "expo-camera",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6ba651e5-25d9-4170-903d-61da76ba3678"
      }
    },
    "owner": "zemdenalex"
  }
}
