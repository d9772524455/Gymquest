# Gym Quest — Environment Config
# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL=postgresql://gymquest:your_password@localhost:5432/gymquest

# JWT
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING

# Optional: Email for retention alerts
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=alerts@gymquest.ru
# SMTP_PASS=your_app_password
